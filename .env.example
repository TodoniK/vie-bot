# URL du webhook Discord (obligatoire)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Intervalle entre chaque vérification (secondes, défaut: 60)
# CHECK_INTERVAL=60

# Nombre max d'offres à récupérer (défaut: 5000)
# SEARCH_LIMIT=5000

# Niveau de log: DEBUG, INFO, WARNING, ERROR (défaut: INFO)
# LOG_LEVEL=INFO
